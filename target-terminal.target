<?pde version="3.8"?>
<target name="Copilot for Eclipse Target Definition - Terminal">
	<locations>
		<location includeAllPlatforms="false" includeConfigurePhase="false" includeMode="planner"
            includeSource="true" type="InstallableUnit">
